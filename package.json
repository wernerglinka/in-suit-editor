{
  "name": "metalsmith2025-simple-starter",
  "version": "1.0.0",
  "description": "A simple Metalsmith starter for 2025",
  "type": "module",
  "keywords": [
    "metalsmith",
    "starter"
  ],
  "author": "werner@glinka.co",
  "license": "MIT",
  "scripts": {
    "dev": "metalsmith -c metalsmith.js --env NODE_ENV=development",
    "dev:debug": "metalsmith -c metalsmith.js --env NODE_ENV=development --env DEBUG=@metalsmith*",
    "dev:subdomain": "metalsmith -c metalsmith.js --env NODE_ENV=development --env BASE_PATH=metalsmith2025-simple-starter",
    "dev:subdomain:debug": "metalsmith -c metalsmith.js --env NODE_ENV=development --env DEBUG=@metalsmith* --env BASE_PATH=metalsmith2025-simple-starter",
    "build": "metalsmith -c metalsmith.js --env NODE_ENV=production",
    "build:subdomain": "metalsmith -c metalsmith.js --env NODE_ENV=production --env BASE_PATH=metalsmith2025-simple-starter",
    "start": "NODE_ENV=development node metalsmith.js --watch",
    "start:debug": "NODE_ENV=development DEBUG=@metalsmith* node metalsmith.js --watch",
    "start:subdomain": "NODE_ENV=development BASE_PATH=metalsmith2025-simple-starter node metalsmith.js --watch",
    "start:subdomain:debug": "NODE_ENV=development DEBUG=@metalsmith* BASE_PATH=metalsmith2025-simple-starter node metalsmith.js --watch",
    "serve": "browser-sync start --server 'build'",
    "format": "prettier --write \"**/*.{js,json,njk,css}\"",
    "lint": "eslint --fix .",
    "fix": "npm run format && npm run lint",
    "depcheck": "depcheck",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "release:check": "release-it --dry-run"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "eslint": "^10.0.1",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4"
  },
  "dependencies": {
    "@metalsmith/drafts": "^1.3.0",
    "@metalsmith/layouts": "^3.0.0",
    "@metalsmith/permalinks": "^3.2.0",
    "browser-fs-access": "^0.38.0",
    "depcheck": "^1.4.7",
    "jstransformer-nunjucks": "^1.2.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.6",
    "metalsmith": "^2.7.0",
    "metalsmith-blog-lists": "^2.1.1",
    "metalsmith-menu-plus": "^0.3.0",
    "metalsmith-optimize-html": "^0.8.3",
    "metalsmith-safe-links": "^2.1.0",
    "metalsmith-simple-pagination": "^0.1.0",
    "metalsmith-sitemap": "^1.2.2",
    "metalsmith-unified-markdown": "^0.0.4",
    "prismjs": "^1.30.0",
    "rehype-highlight": "^7.0.2",
    "turndown": "^7.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
