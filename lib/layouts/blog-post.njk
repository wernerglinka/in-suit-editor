{% extends "layout.njk" %} {% block body %}
<div class="container">
  <article class="blog-post">
    <h1>{{ title }}</h1>
    <time datetime="{{ date }}">{{ date | blogDate }}</time>

    {% if image %}
    <img class="blog-image" src="{{ image }}" alt="{{ title }}" />
    {% endif %}

    {{ contents | safe }}
  </article>
</div>
{% endblock %}
